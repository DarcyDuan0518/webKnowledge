; position: absolute; inset: 0px; background-color: rgba(0, 0, 0, 0.1); }

.pay button:not(.btn_disabled):active::after { content: ""; position: absol=
ute; inset: 0px; background-color: rgba(0, 0, 0, 0.1); }

.pay button.btn_disabled { background-color: rgb(242, 242, 242); color: rgb=
a(0, 0, 0, 0.18); }

.pay_new button { background-color: rgb(7, 193, 96); font-size: 14px; min-h=
