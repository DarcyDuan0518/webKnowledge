.pay_new .weui-btn_primary { background-color: rgb(7, 193, 96); }

.pay_new .weui-btn_primary:not(.weui-btn_disabled):active { background-colo=
r: rgb(7, 193, 96); }

.pay__mask { position: absolute; width: 100%; left: 0px; bottom: 0px; text-=
