 class=3D"language-text"> #include &lt;stdio.h&gt;

typedef struct shape {
    void (*draw)(void* shape);
} Shape;

typedef struct {
    Shape base;
    int x;
    int y;
    int radius;
} Circle;

typedef struct {
    Shape base;
    int x1;
    int y1;
    int x2;
    int y2;
} Line;

void drawCircle(void* shape) {
    Circle* circle =3D (Circle*)shape;
    printf("Circle at (%d,%d) with radius %d\n", circle-&gt;x, circle-&gt;y=
, circle-&gt;radius);
}

void drawLine(void* shape) {
    Line* line =3D (Line*)shape;
    printf("Line from (%d,%d) to (%d,%d)\n", line-&gt;x1, line-&gt;y1, line=
-&gt;x2, line-&gt;y2);
}

int main() {
    Circle circle =3D {
        .base =3D { .draw =3D drawCircle }
        .x =3D 1,
        .y =3D 5,
        .radius =3D 10,
    };

    Line line =3D {
        .base =3D { .draw =3D drawLine }
        .x1 =3D 2,
        .y1 =3D 3,
        .x2 =3D 7,
        .y2 =3D 9,
    };

    Shape* shapes[2];
    shapes[0] =3D (Shape*)&amp;circle;
    shapes[1] =3D (Shape*)&amp;line;

    for (int i =3D 0; i &lt; 2; i++) {
        shapes[i]-&gt;draw(shapes[i]);
    }

    return 0;
}</code></pre></div><p data-pid=3D"xW9UJNCL">=E5=9C=A8=E4=B8=8A=E9=9D=A2=E7=
