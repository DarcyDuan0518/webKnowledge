re; display: flex; position: relative; font-family: Consolas, "Liberation M=
ono", Menlo, Courier, monospace; }

.code-snippet__fix .code-snippet__line-index { counter-reset: line 0; flex-=
shrink: 0; height: 100%; padding: 1em; list-style-type: none; }

.code-snippet__fix .code-snippet__line-index li { list-style-type: none; te=
xt-align: right; }

