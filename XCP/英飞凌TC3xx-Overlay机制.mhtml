.rich_media_tool_area { margin-top: 32px; padding-bottom: 20px; }

.rich_media_tool { font-size: 14px; line-height: 1.4; overflow: visible; le=
tter-spacing: 0px; }

.rich_media_tool .rich_media_info { flex-wrap: wrap; margin-bottom: 20px; }

.rich_media_tool .rich_media_info.rich_media_bottom { margin-bottom: 0px; }

.rich_media_tool .rich_media_info:empty { display: none; }

.rich_media_tool .media_tool_meta { float: none; flex-shrink: 0; max-width:=
 100%; }

.rich_media_tool .meta_primary { margin-right: 12px; }

.rich_media_tool .meta_primary:last-child { margin-right: 0px; }

.rich_media_tool .meta_extra { color: rgb(87, 107, 149); margin-left: 12px;=
 }

.rich_media_tool .meta_extra:first-child { margin-left: 0px; }

.rich_media_tool .meta_praise { min-width: 0px; color: rgb(87, 107, 149); }

.rich_media_tool .sns_opr_area { justify-content: space-between; align-item=
s: center; }

.rich_media_tool .sns_opr_area .media_tool_meta { display: inline-flex; ver=
tical-align: top; white-space: nowrap; }

.rich_media_tool .sns_opr_area .meta_primary:not(:last-child) { margin-righ=
t: 32px; }

.rich_media_tool .sns_opr_area .meta_extra:not(:first-child) { margin-left:=
 32px; }

.rich_media_tool .sns_opr_area_smart .sns_opr_btn { color: var(--weui-LINK)=
; }

