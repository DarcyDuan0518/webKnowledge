.player-loading__head { position: absolute; bottom: 0px; }

.infinity-list__wrapper { position: relative; }

.infinity-list__wrapper::-webkit-scrollbar { display: none; }

.destory-leave { display: none; }

.feed-mask { width: 9999px; height: 9999px; position: fixed; top: -50%; lef=
t: -50%; background-color: rgb(0, 0, 0); }

.fullscreen-screenshot__layer { position: fixed; bottom: 0px; left: 0px; ri=
ght: 0px; height: 100%; background-size: 100%; background-position: center =
bottom; }

.video-scroll-list__wrapper { position: fixed; top: 0px; left: 0px; width: =
100vw; min-height: 100vh; overflow: hidden visible; z-index: 1; }

.page_video_wrapper { height: 100%; }

.infinity-list__loading-custom { width: 100vw; height: 136px; display: flex=
; align-items: center; justify-content: center; }

.feed_faded_in { animation: 0.6s ease-in 0s 1 normal forwards running feedS=
howIn; }

@keyframes feedShowIn {=20
  0% { opacity: 1; }
  15% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes topTipsShowIn {=20
  0% { transform: translateY(-80px); }
  100% { transform: translateY(0px); }
}

@keyframes topTipsShowOut {=20
  0% { transform: translateY(0px); }
  100% { transform: translateY(-80px); }
}

@-webkit-keyframes videoLoading {=20
  0% { transform: rotate3d(0, 0, 1, 0deg); }
  100% { transform: rotate3d(0, 0, 1, 360deg); }
}

@keyframes videoLoading {=20
  0% { transform: rotate3d(0, 0, 1, 0deg); }
  100% { transform: rotate3d(0, 0, 1, 360deg); }
}

@keyframes midAdShowIn {=20
  0% { transform: translate(100vw); opacity: 0; }
  100% { transform: translate(0px); opacity: 1; }
}

