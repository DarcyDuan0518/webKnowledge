.cookie_pannel_nav_item_mobile { height: 50px; padding: 0px 20px 0px 0px; w=
idth: 100%; line-height: 49px; border-bottom: 1px solid rgb(212, 212, 212);=
 white-space: nowrap; text-overflow: ellipsis; overflow: hidden; position: =
relative; }

.cookie_dialog_footer_mobile { height: 63px; line-height: 62px; position: f=
ixed; text-align: center; border-top: 1px solid rgb(212, 212, 212); bottom:=
 0px; right: 0px; width: 100%; }

.cookie_dialog_header_mobile { width: 100%; height: 120px; padding: 32px 0p=
x 24px; text-align: center; background: rgb(224, 224, 224); }

.cookie_logo_mobile { text-align: center; }

.cookie_logo_mobile_logo { display: inline-block; vertical-align: middle; w=
idth: 44px; background-size: cover; }

.cookie_logo_text_mobile { margin-left: 6px; font-weight: 700; display: inl=
ine-block; vertical-align: middle; }

.cookie_logo_text_mobile, .cookie_title_mobile { font-family: PingFangSC-Se=
mibold; font-size: 20px; }

.cookie_title_mobile { text-align: center; display: block; color: rgb(0, 0,=
 0); letter-spacing: 0px; line-height: 20px; padding-top: 12px; }

.cookie_dialog_body_mobile { padding: 0px; background: rgb(255, 255, 255); =
}

