ive; background-color: rgb(250, 250, 250); border: 1px solid rgb(240, 240, =
240); border-radius: 2px; counter-reset: line 0; white-space: normal; }

.code-snippet code { text-align: left; font-size: 14px; display: block; whi=
te-space: pre-wrap; position: relative; font-family: Consolas, "Liberation =
Mono", Menlo, Courier, monospace; }

.code-snippet code::before { position: absolute; min-width: 1.5em; text-ali=
gn: right; left: -2.5em; counter-increment: line 1; content: counter(line);=
 display: inline; margin-right: 12px; color: rgba(0, 0, 0, 0.15); }

.code-snippet_nowrap code { white-space: pre; display: flex; }

