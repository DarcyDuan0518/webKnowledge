r(--weui-FG-3); }

.weui-slider__track { height: 100%; background-color: var(--weui-BRAND); wi=
dth: 0px; }

.weui-slider__handler { position: absolute; left: 0px; top: 50%; width: 28p=
x; height: 28px; margin-left: -14px; margin-top: -14px; border-radius: 50%;=
 background-color: rgb(255, 255, 255); box-shadow: 0 0 4px var(--weui-FG-3)=
; }

