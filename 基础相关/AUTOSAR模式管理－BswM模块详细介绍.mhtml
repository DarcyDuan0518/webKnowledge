 text-align: right; left: -2.5em; counter-increment: line 1; content: count=
er(line); display: inline; color: rgba(0, 0, 0, 0.15); }

.code-snippet__comment, .code-snippet__quote { color: rgb(175, 175, 175); f=
ont-style: italic; }

.code-snippet__keyword, .code-snippet__selector-tag, .code-snippet__subst {=
 color: rgb(202, 125, 55); }

