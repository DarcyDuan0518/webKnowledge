@charset "utf-8";

.cookie_dialog tbody, td, tfoot, th, thead, tr { border-width: inherit; }

.cookie_statement { display: flex; justify-content: space-between; position=
: fixed; bottom: 0px; left: 0px; right: 0px; background: rgba(0, 0, 0, 0.86=
); color: rgb(255, 255, 255); padding: 20px 100px; z-index: 2000; }

.cookie_logo { width: 44px; }

.cookie_logo_text { margin-left: 6px; font-size: 22px; font-weight: 700; }

.cookie_title { margin-left: 14px; font-family: PingFangSC-Semibold; font-s=
ize: 20px; font-weight: 700; }

.cookie_left { flex: 1 1 0%; padding-right: 40px; font-size: 14px; }

.cookie_more_btn { cursor: pointer; text-decoration: underline; }

.cookie_learn_link { font-size: 12px; color: rgb(255, 255, 255); text-decor=
ation: underline; }

.cookie_btn, .cookie_setting_btn { display: inline-block; padding: 0px 16px=
; cursor: pointer; }

.cookie_btn { line-height: 28px; color: rgb(255, 255, 255); font-size: 14px=
; border: 1px solid rgb(255, 255, 255); user-select: none; }

.cookie_btn_primary { border-color: rgb(246, 111, 106); background-color: r=
gb(246, 111, 106); }

.cookie_btn_primary:hover { border-color: rgb(246, 111, 106); background-co=
lor: rgb(246, 111, 106); }

.cookie_btn_danger { border-color: rgb(245, 34, 45); background-color: rgb(=
245, 34, 45); }

.cookie_btn_danger:hover { border-color: rgb(255, 77, 79); background-color=
: rgb(255, 77, 79); }

.cookie_reject_btn { margin-left: 8px; }

.cookie_reject_btn .icon_close { fill: rgb(255, 255, 255); width: 1.2em; he=
ight: 1.2em; vertical-align: middle; }

.cookie_mask { position: absolute; inset: 0px; background: rgba(0, 0, 0, 0.=
3); z-index: 2000; }

.cookie_dialog { width: 820px; margin: 0px auto; background: rgb(255, 255, =
255); z-index: 2001; position: absolute; top: 20%; left: 50%; transform: tr=
anslate(-50%); }

.cookie_dialog_header { display: flex; align-items: center; padding: 12px 2=
6px; vertical-align: middle; background: rgb(224, 224, 224); }

.cookie_dialog_header .icon_close { position: absolute; right: 12px; top: 1=
2px; fill: rgb(144, 144, 144); width: 2em; height: 2em; cursor: pointer; }

.cookie_dialog_body { padding: 22px 22px 20px; background: rgb(255, 255, 25=
5); border: 1px solid rgb(204, 204, 204); }

.cookie_dialog_footer { display: flex; justify-content: space-between; padd=
ing: 16px 24px 24px; font-size: 14px; }

.cookie_pannel { display: flex; }

.cookie_pannel_nav { border-top: 1px solid rgb(217, 217, 217); border-right=
: 1px solid rgb(217, 217, 217); border-left: 1px solid rgb(217, 217, 217); =
border-image: initial; border-bottom: none; }

.cookie_pannel_nav_item { box-sizing: content-box; position: relative; over=
flow: hidden; width: 180px; line-height: 46px; border-bottom: 1px solid rgb=
(217, 217, 217); font-size: 14px; text-align: center; user-select: none; wh=
ite-space: nowrap; text-overflow: ellipsis; cursor: pointer; }

.cookie_pannel_nav_item.active { border: 1px solid rgb(24, 144, 255); color=
: rgb(24, 144, 255); font-weight: 700; margin: -1px; }

.cookie_pannel_nav_item.active .active_icon { display: block; }

.cookie_pannel_nav_item .active_icon { display: none; width: 28px; height: =
28px; position: absolute; right: -14px; bottom: -14px; transform: rotate(45=
deg); background-color: rgb(24, 144, 255); }

.cookie_pannel_nav_item .active_icon svg { fill: rgb(255, 255, 255); width:=
 1em; height: 1em; position: absolute; transform: rotate(-45deg); right: 14=
px; bottom: 8px; }

.cookie_pannel_content { flex: 1 1 0%; padding: 8px 0px 0px 32px; overflow:=
 hidden; }

.cookie_pannel_content.more { padding-top: 0px; }

.cookie_active_color { color: rgb(24, 144, 255); }

.cookie_pannel_content_title { font-size: 18px; padding-bottom: 20px; }

.cookie_pannel_content_title.more { margin-bottom: 17px; height: 28px; padd=
ing-bottom: 0px; border-bottom: 1px solid rgb(217, 217, 217); }

.cookie_content_more_sub_title { font-family: PingFangSC-Semibold; font-siz=
e: 14px; color: grey; letter-spacing: 0px; line-height: 14px; display: inli=
ne-block; vertical-align: middle; padding: 0px 4px 8px; font-weight: 400; c=
ursor: pointer; max-width: 45%; white-space: nowrap; text-overflow: ellipsi=
s; overflow: hidden; }

.cookie_content_more_sub_title.active { font-weight: 700; color: rgb(24, 14=
4, 255); border-bottom: 3px solid; }

.cookie_content_more_sub_title.CookieList { margin-left: 34px; }

.cookie_pannel_content_body { height: 210px; overflow: auto; color: rgb(51,=
 51, 51); }

.cookie_accept_dialog_btn { margin-right: 10px; }

.cookie_pannel_content_item:not(:first-child) { display: none; }

.cookie_powered_by_one_trust { color: rgb(74, 74, 74); }

.cookie_checkbox { float: left; position: relative; width: 40px; height: 20=
px; border-radius: 10px; background: rgb(217, 217, 217); cursor: pointer; }

.cookie_checkbox.Essential { cursor: no-drop; }

.cookie_checkbox_wrap { display: flex; justify-content: space-between; min-=
width: 120px; float: right; font-size: 14px; color: rgb(74, 74, 74); }

@media screen and (max-width: 1024px) {
  .cookie_statement { padding: 14px 16px; z-index: 3000; display: block; }
  .cookie_left { font-family: HelveticaNeue; font-size: 10px; color: rgb(25=
5, 255, 255); text-align: justify; line-height: 16px; display: block; flex:=
 0 0 auto; width: 100%; padding-right: 0px; overflow: hidden; height: auto;=
 }
  .cookie_more_btn { padding-left: 3px; }
  .cookie_right { margin-top: 16px; height: 24px; text-align: left; line-he=
ight: 24px; }
  .cookie_setting_btn { font-size: 10px; padding: 0px 16px 0px 0px; text-de=
coration: underline; }
  .cookie_accept_btn, .cookie_reject_btn { font-size: 10px; height: 24px; l=
ine-height: 22px; vertical-align: middle; }
}

.cookie_dialog_mobile { width: 100%; margin: 0px; background: rgb(255, 255,=
